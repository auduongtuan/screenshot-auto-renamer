<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.tuan.screenshot-auto-renamer</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/tuan/Code/screenshot_auto_renamer/target/release/screenshot_auto_renamer</string>
    <string>--watch-dir</string>
    <string>/Users/tuan/Library/CloudStorage/Dropbox/screenshots</string>
    <string>--verbose</string>
    <string>--polling</string>
    <string>--use-gemini-summary</string>
    <string>--debug-gemini-prompt</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/tuan/Code/screenshot_auto_renamer/target/release</string>

  <key>EnvironmentVariables</key>
  <dict>
